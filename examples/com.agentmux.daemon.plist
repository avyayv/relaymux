<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agentmux.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/usr/local/bin/agentmux</string>
    <string>--config</string>
    <string>/Users/YOU/.config/agentmux/config.json</string>
    <string>daemon</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/YOU</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/YOU/.local/state/agentmux/logs/daemon.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOU/.local/state/agentmux/logs/daemon.err.log</string>
</dict>
</plist>
